{
	"name": "unsolved-problems",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"workspaces": [
		"apps/*"
	],
	"scripts": {
		"postinstall": "git rev-parse --git-dir >/dev/null 2>&1 && git config core.hooksPath .githooks || true",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"typecheck": "bun run --workspaces typecheck",
		"test": "bun test --coverage"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.4"
	}
}
